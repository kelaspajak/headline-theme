{{!< default}}

<main class="gh-main gh-outer">
    <div class="gh-inner">
        {{#author}}
            <section class="gh-pagehead">
                <figure class="gh-author-image">
                    {{#if profile_image}}
                        <img
                            srcset="{{img_url profile_image size="xs"}} 150w,
                                    {{img_url profile_image size="s"}} 300w"
                            sizes="150px"
                            src="{{img_url profile_image size="xs"}}"
                            alt="{{name}}"
                        >
                    {{else}}
                        <div class="gh-author-icon">{{> icons/avatar}}</div>
                    {{/if}}
                </figure>

                <div class="gh-pagehead-content">
                    <h1 class="gh-pagehead-title">{{name}}</h1>
                    {{#if location}}
                        <div class="gh-author-location">{{location}}</div>
                    {{/if}}
                    {{#if bio}}
                        <div class="gh-author-bio gh-pagehead-description">{{bio}}</div>
                    {{/if}}
                    <div class="gh-author-social">
                    {{#if website}}
                            <a class="gh-author-social-link" href="{{website}}" target="_blank" rel="noopener" aria-label="Website">{{> "icons/website"}}</a>
                        {{/if}}
                        {{#if twitter}}
                            <a class="gh-author-social-link" href="{{social_url type="twitter"}}" target="_blank" rel="noopener" aria-label="Twitter">{{> "icons/x"}}</a>
                        {{/if}}
                        {{#if facebook}}
                            <a class="gh-author-social-link" href="{{social_url type="facebook"}}" target="_blank" rel="noopener" aria-label="Facebook">{{> "icons/facebook"}}</a>
                        {{/if}}

                        {{#social_accounts author}}
                        <a href="{{href}}" target="_blank" rel="noopener" aria-label="{{name}}" class="gh-author-social-link">
                            {{#> (concat "icons/" type)}}
                            <span>{{name}}</span>
                            {{/undefined}}
                        </a>
                        {{/social_accounts}}
                    </div>
                </div>
            </section>
        {{/author}}

        <div class="gh-topic gh-topic-grid">
            <div class="gh-topic-content gh-feed">
                {{#foreach posts}}
                    {{> "loop-grid"}}
                {{/foreach}}
            </div>
        </div>
    </div>
</main>
