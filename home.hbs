{{!< default}}

{{#contentFor "head"}}
<style>
/* ═══════════════════════════════════════════
   HOMEPAGE — Ghost.org-inspired layout
   ═══════════════════════════════════════════ */

/* ── Reset body class ── */
.home-template .gh-main { padding-top: 0; }

/* ═══════════════════════════════════════════
   HERO
   ═══════════════════════════════════════════ */
.dp-hero {
    position: relative;
    padding: 12vmin 24px 8vmin;
    text-align: center;
    background: linear-gradient(180deg, var(--color-lighter-gray) 0%, var(--color-white) 100%);
    overflow: hidden;
}
.dp-hero-inner {
    max-width: 720px;
    margin: 0 auto;
}
.dp-hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 14px;
    background: var(--color-white);
    border: 1px solid var(--color-light-gray);
    border-radius: 100px;
    font-size: 1.25rem;
    color: var(--color-secondary-text);
    margin-bottom: 24px;
}
.dp-hero-badge-dot {
    width: 8px;
    height: 8px;
    background: #22c55e;
    border-radius: 50%;
}
.dp-hero-title {
    font-family: var(--font-serif);
    font-size: 4rem;
    font-weight: 800;
    color: var(--color-darkgrey);
    margin: 0 0 20px;
    line-height: 1.15;
    letter-spacing: -0.025em;
}
@media (min-width: 768px) {
    .dp-hero-title { font-size: 5.6rem; }
}
@media (max-width: 480px) {
    .dp-hero-title { font-size: 3rem; }
}
.dp-hero-title-accent {
    color: var(--color-tag, #1e40af);
}
.dp-hero-desc {
    font-size: 1.6rem;
    line-height: 1.6;
    color: var(--color-secondary-text);
    margin: 0 auto 32px;
    max-width: 560px;
}
.dp-hero-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 40px;
}
.dp-hero-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    border-radius: 8px;
    font-size: 1.4rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.15s ease;
}
.dp-hero-btn-primary {
    background: var(--color-darkgrey);
    color: var(--color-white);
}
.dp-hero-btn-primary:hover {
    opacity: 0.85;
    transform: translateY(-1px);
}
.dp-hero-btn-secondary {
    background: var(--color-white);
    color: var(--color-darkgrey);
    border: 1px solid var(--color-light-gray);
}
.dp-hero-btn-secondary:hover {
    background: var(--color-lighter-gray);
}

/* ── Hero Stats ── */
.dp-hero-stats {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 32px;
    flex-wrap: wrap;
    padding-top: 24px;
    border-top: 1px solid var(--color-light-gray);
}
.dp-stat {
    text-align: center;
}
.dp-stat-num {
    font-family: var(--font-serif);
    font-size: 2.4rem;
    font-weight: 800;
    color: var(--color-darkgrey);
    line-height: 1;
    margin-bottom: 4px;
}
.dp-stat-label {
    font-size: 1.15rem;
    color: var(--color-secondary-text);
}

/* ═══════════════════════════════════════════
   FEATURE CARDS
   ═══════════════════════════════════════════ */
.dp-features {
    max-width: 1100px;
    margin: 0 auto;
    padding: 8vmin 24px;
}
.dp-section-label {
    font-size: 1.15rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-mid-gray);
    text-align: center;
    margin: 0 0 8px;
}
.dp-section-title {
    font-family: var(--font-serif);
    font-size: 2.8rem;
    font-weight: 700;
    color: var(--color-darkgrey);
    text-align: center;
    margin: 0 0 12px;
    line-height: 1.25;
}
@media (min-width: 768px) {
    .dp-section-title { font-size: 3.4rem; }
}
.dp-section-desc {
    font-size: 1.4rem;
    color: var(--color-secondary-text);
    text-align: center;
    margin: 0 auto 40px;
    max-width: 520px;
    line-height: 1.6;
}
.dp-features-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
}
@media (min-width: 640px) {
    .dp-features-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (min-width: 960px) {
    .dp-features-grid { grid-template-columns: repeat(3, 1fr); }
}
.dp-feature-card {
    background: var(--color-white);
    border: 1px solid var(--color-light-gray);
    border-radius: 12px;
    padding: 28px 24px;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
}
.dp-feature-card:hover {
    box-shadow: 0 4px 20px rgba(0,0,0,0.06);
    transform: translateY(-2px);
}
.dp-feature-icon {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 16px;
    font-size: 1.8rem;
}
.dp-feature-title {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-darkgrey);
    margin: 0 0 8px;
    line-height: 1.3;
}
.dp-feature-desc {
    font-size: 1.3rem;
    line-height: 1.55;
    color: var(--color-secondary-text);
    margin: 0;
}
.dp-feature-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 14px;
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-darkgrey);
    text-decoration: none;
    transition: gap 0.2s ease;
}
.dp-feature-link:hover { gap: 10px; }

/* ═══════════════════════════════════════════
   LOGO / INTEGRATION BAR
   ═══════════════════════════════════════════ */
.dp-logos {
    max-width: 900px;
    margin: 0 auto;
    padding: 6vmin 24px;
    text-align: center;
}
.dp-logos-label {
    font-size: 1.2rem;
    color: var(--color-mid-gray);
    margin: 0 0 24px;
}
.dp-logos-grid {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 32px;
    flex-wrap: wrap;
    opacity: 0.5;
}
.dp-logos-grid img {
    height: 28px;
    width: auto;
    filter: grayscale(100%);
}

/* ═══════════════════════════════════════════
   USE CASE SECTIONS
   ═══════════════════════════════════════════ */
.dp-usecase {
    max-width: 1100px;
    margin: 0 auto;
    padding: 6vmin 24px;
}
.dp-usecase-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    margin-top: 32px;
}
@media (min-width: 768px) {
    .dp-usecase-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (min-width: 1024px) {
    .dp-usecase-grid { grid-template-columns: repeat(4, 1fr); }
}
.dp-usecase-card {
    background: var(--color-lighter-gray);
    border-radius: 12px;
    padding: 24px;
    text-decoration: none;
    color: inherit;
    transition: background 0.15s ease;
}
.dp-usecase-card:hover {
    background: var(--color-light-gray);
}
.dp-usecase-card-icon {
    font-size: 2rem;
    margin-bottom: 12px;
}
.dp-usecase-card-title {
    font-family: var(--font-serif);
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--color-darkgrey);
    margin: 0 0 6px;
}
.dp-usecase-card-desc {
    font-size: 1.25rem;
    color: var(--color-secondary-text);
    margin: 0;
    line-height: 1.5;
}

/* ═══════════════════════════════════════════
   TESTIMONIAL / SOCIAL PROOF
   ═══════════════════════════════════════════ */
.dp-testimonials {
    max-width: 1100px;
    margin: 0 auto;
    padding: 8vmin 24px;
}
.dp-testimonials-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    margin-top: 32px;
}
@media (min-width: 768px) {
    .dp-testimonials-grid { grid-template-columns: repeat(3, 1fr); }
}
.dp-testimonial {
    background: var(--color-white);
    border: 1px solid var(--color-light-gray);
    border-radius: 12px;
    padding: 24px;
}
.dp-testimonial-quote {
    font-family: var(--font-serif);
    font-size: 1.35rem;
    font-style: italic;
    color: var(--color-darkgrey);
    line-height: 1.55;
    margin: 0 0 16px;
}
.dp-testimonial-author {
    display: flex;
    align-items: center;
    gap: 10px;
}
.dp-testimonial-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    object-fit: cover;
    background: var(--color-light-gray);
}
.dp-testimonial-name {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-darkgrey);
}
.dp-testimonial-role {
    font-size: 1.1rem;
    color: var(--color-secondary-text);
}

/* ═══════════════════════════════════════════
   SECTION DIVIDER
   ═══════════════════════════════════════════ */
.dp-divider {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
}
.dp-divider hr {
    border: none;
    border-top: 1px solid var(--color-light-gray);
    margin: 0;
}

/* ═══════════════════════════════════════════
   CTA SECTION
   ═══════════════════════════════════════════ */
.dp-cta {
    max-width: 800px;
    margin: 0 auto;
    padding: 8vmin 24px;
    text-align: center;
}
.dp-cta-title {
    font-family: var(--font-serif);
    font-size: 2.8rem;
    font-weight: 700;
    color: var(--color-darkgrey);
    margin: 0 0 12px;
    line-height: 1.25;
}
@media (min-width: 768px) {
    .dp-cta-title { font-size: 3.4rem; }
}
.dp-cta-desc {
    font-size: 1.4rem;
    color: var(--color-secondary-text);
    margin: 0 auto 28px;
    max-width: 480px;
    line-height: 1.6;
}
.dp-cta-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    flex-wrap: wrap;
}
</style>
{{/contentFor}}

<main class="gh-main">

{{!-- ═══════════════════════════════════════════════
     HERO
     ═══════════════════════════════════════════════ --}}
<section class="dp-hero">
    <div class="dp-hero-inner">
        <div class="dp-hero-badge">
            <span class="dp-hero-badge-dot"></span>
            Referensi perpajakan terpercaya
        </div>
        <h1 class="dp-hero-title">
            Pajak <span class="dp-hero-title-accent">semudah</span><br />
            yang seharusnya.
        </h1>
        <p class="dp-hero-desc">
            Panduan perpajakan dalam bahasa yang mudah dipahami. Dari PPh, PPN, sampai SPT — semua yang perlu Anda ketahui, tersedia di sini.
        </p>
        <div class="dp-hero-actions">
            <a class="dp-hero-btn dp-hero-btn-primary" href="/resources/">
                Mulai Belajar →
            </a>
            <a class="dp-hero-btn dp-hero-btn-secondary" href="/tag/tutorial/">
                Lihat Panduan
            </a>
        </div>
        <div class="dp-hero-stats">
            <div class="dp-stat">
                <div class="dp-stat-num">991+</div>
                <div class="dp-stat-label">Artikel</div>
            </div>
            <div class="dp-stat">
                <div class="dp-stat-num">40+</div>
                <div class="dp-stat-label">Topik Pajak</div>
            </div>
            <div class="dp-stat">
                <div class="dp-stat-num">100%</div>
                <div class="dp-stat-label">Gratis</div>
            </div>
        </div>
    </div>
</section>

<div class="dp-divider"><hr /></div>

{{!-- ═══════════════════════════════════════════════
     LEARNING PATH (seperti Ghost feature cards)
     ═══════════════════════════════════════════════ --}}
<section class="dp-features">
    <p class="dp-section-label">Belajar Sesuai Kebutuhan</p>
    <h2 class="dp-section-title">Pilih jalur yang cocok untuk Anda</h2>
    <p class="dp-section-desc">Tiap jalur dirancang sesuai kondisi Anda — dari pemula yang baru kenal pajak sampai praktisi yang butuk update regulasi.</p>
    <div class="dp-features-grid">
        <div class="dp-feature-card">
            <div class="dp-feature-icon" style="background: #dbeafe; color: #1e40af;">📖</div>
            <h3 class="dp-feature-title">Dasar Pajak</h3>
            <p class="dp-feature-desc">Bingung mulai dari mana? Belajar konsep dasar: apa itu pajak, jenis-jurusannya, dan kenapa penting untuk Anda.</p>
            <a class="dp-feature-link" href="/tag/tutorial/">Mulai belajar →</a>
        </div>
        <div class="dp-feature-card">
            <div class="dp-feature-icon" style="background: #d1fae5; color: #065f46;">👤</div>
            <h3 class="dp-feature-title">Saya Karyawan</h3>
            <p class="dp-feature-desc">Gaji dipotong pajak? Pelajari PPh 21, cara hitung PTKP, dan isian SPT Tahunan untuk karyawan.</p>
            <a class="dp-feature-link" href="/tag/wp-op/">Pelajari PPh 21 →</a>
        </div>
        <div class="dp-feature-card">
            <div class="dp-feature-icon" style="background: #fef3c7; color: #92400e;">🏪</div>
            <h3 class="dp-feature-title">Saya Pemilik UMKM</h3>
            <p class="dp-feature-desc">Usaha kena pajak apa? Panduan lengkap PPh Final UMKM 0.5%, PPN PKP, dan e-Faktur.</p>
            <a class="dp-feature-link" href="/tag/umkm/">Panduan UMKM →</a>
        </div>
        <div class="dp-feature-card">
            <div class="dp-feature-icon" style="background: #e0e7ff; color: #3730a3;">📋</div>
            <h3 class="dp-feature-title">Pelaporan SPT</h3>
            <p class="dp-feature-desc">Langkah demi langkah isi dan kirim SPT Tahunan / Masa. Lengkap dengan screenshot.</p>
            <a class="dp-feature-link" href="/tag/spt/">Cara lapor SPT →</a>
        </div>
        <div class="dp-feature-card">
            <div class="dp-feature-icon" style="background: #fee2e2; color: #991b1b;">⚠️</div>
            <h3 class="dp-feature-title">Ada Masalah Pajak</h3>
            <p class="dp-feature-desc">Dapat surat DJP, SKPKB, atau SP2DK? Kenali hak dan langkah yang harus diambil.</p>
            <a class="dp-feature-link" href="/tag/pemeriksaan/">Solusi masalah →</a>
        </div>
        <div class="dp-feature-card">
            <div class="dp-feature-icon" style="background: #f3e8ff; color: #6b21a8;">📢</div>
            <h3 class="dp-feature-title">Update Regulasi</h3>
            <p class="dp-feature-desc">Ringkasan cepat PMK, PER, SE terbaru yang berdampak langsung ke Anda.</p>
            <a class="dp-feature-link" href="/tag/update-regulasi/">Update terbaru →</a>
        </div>
    </div>
</section>

<div class="dp-divider"><hr /></div>

{{!-- ═══════════════════════════════════════════════
     TOPIK POPULER (seperti Ghost use cases)
     ═══════════════════════════════════════════════ --}}
<section class="dp-usecase">
    <p class="dp-section-label">Topik Populer</p>
    <h2 class="dp-section-title">Jelajahi berdasarkan jenis pajak</h2>
    <div class="dp-usecase-grid">
        {{#get "tags" filter="slug:[pph,ppn,spt,pemeriksaan,umkm,coretax]" limit="6" include="count.posts"}}
        {{#foreach tags}}
        <a class="dp-usecase-card" href="{{url}}" style="--color-tag: {{accent_color}};">
            <div class="dp-usecase-card-icon">
                {{#if accent_color}}
                <span style="display:inline-block;width:12px;height:12px;border-radius:50%;background:{{accent_color}};"></span>
                {{else}}
                📄
                {{/if}}
            </div>
            <h3 class="dp-usecase-card-title">{{name}}</h3>
            <p class="dp-usecase-card-desc">{{description}}</p>
        </a>
        {{/foreach}}
        {{/get}}
    </div>
</section>

<div class="dp-divider"><hr /></div>

{{!-- ═══════════════════════════════════════════════
     REGULATION TRACKER (seperti Ghost latest posts)
     ═══════════════════════════════════════════════ --}}
<section class="dp-features" style="padding-top: 6vmin;">
    <p class="dp-section-label">Update Regulasi</p>
    <h2 class="dp-section-title">Peraturan perpajakan terbaru</h2>
    <p class="dp-section-desc">Ringkasan cepat PMK, PER, SE, dan KMK yang baru berlaku.</p>
    <div class="dp-usecase-grid" style="margin-top: 32px;">
        {{#get "posts" filter="tag:update-regulasi" limit="4" include="tags"}}
        {{#foreach posts}}
        <a class="dp-usecase-card" href="{{url}}">
            <div class="dp-usecase-card-icon">📅</div>
            <h3 class="dp-usecase-card-title">{{title}}</h3>
            <p class="dp-usecase-card-desc">{{date format="DD MMM YYYY"}} · {{reading_time}}</p>
        </a>
        {{/foreach}}
        {{/get}}
    </div>
</section>

<div class="dp-divider"><hr /></div>

{{!-- ═══════════════════════════════════════════════
     ARTIKEL TERBARU (seperti Ghost latest posts)
     ═══════════════════════════════════════════════ --}}
<section class="dp-features" style="padding-top: 6vmin;">
    <p class="dp-section-label">Artikel Terbaru</p>
    <h2 class="dp-section-title">Bacaan terbaru dari Diskusi Pajak</h2>
    <div style="margin-top: 32px;">
        {{#get "posts" limit="6" include="tags"}}
        {{#foreach posts}}
        <article style="border-bottom: 1px solid var(--color-light-gray); padding: 20px 0;">
            <a href="{{url}}" style="text-decoration: none; color: inherit; display: flex; align-items: baseline; gap: 16px;">
                <time style="flex-shrink: 0; font-size: 1.15rem; color: var(--color-secondary-text); min-width: 90px;">{{date format="DD MMM YYYY"}}</time>
                <div style="flex: 1;">
                    <h3 style="font-family: var(--font-serif); font-size: 1.4rem; font-weight: 600; color: var(--color-darkgrey); margin: 0 0 4px; line-height: 1.35;">{{title}}</h3>
                    {{#foreach tags limit="2"}}
                    <span style="display: inline-block; font-size: 1.05rem; font-weight: 600; padding: 2px 8px; border-radius: 4px; margin-right: 6px; background: {{#if accent_color}}{{accent_color}}15{{else}}var(--color-lighter-gray){{/if}}; color: {{#if accent_color}}{{accent_color}}{{else}}var(--color-secondary-text){{/if}};">{{name}}</span>
                    {{/foreach}}
                </div>
            </a>
        </article>
        {{/foreach}}
        {{/get}}
    </div>
    <div style="text-align: center; margin-top: 28px;">
        <a class="dp-hero-btn dp-hero-btn-secondary" href="/tag/opini/" style="display: inline-flex; align-items: center; gap: 6px; padding: 10px 20px; background: var(--color-white); color: var(--color-darkgrey); border: 1px solid var(--color-light-gray); border-radius: 8px; font-size: 1.3rem; font-weight: 600; text-decoration: none;">Semua artikel →</a>
    </div>
</section>

<div class="dp-divider"><hr /></div>

{{!-- ═══════════════════════════════════════════════
     CTA (seperti Ghost footer CTA)
     ═══════════════════════════════════════════════ --}}
<section class="dp-cta">
    <h2 class="dp-cta-title">Siap memahami pajak?<br />Mulai dari sini.</h2>
    <p class="dp-cta-desc">Diskusi Pajak menyediakan panduan perpajakan yang mudah dipahami, aktersemua orang — bukan hanya akuntan.</p>
    <div class="dp-cta-actions">
        <a class="dp-hero-btn dp-hero-btn-primary" href="/resources/">
            Jelajahi Semua Materi →
        </a>
        <a class="dp-hero-btn dp-hero-btn-secondary" href="/author/tim-redaksi/">
            Tentang Kami
        </a>
    </div>
</section>

</main>
