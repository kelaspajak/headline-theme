{{!-- ── tidak ada menampilkan postingan di halaman ini  ── --}}

{{!< default}}
<style>
/* ── Campfire-style letter inside default.hbs ── */
.cf-letter {
    margin: 0 auto;
    padding: 8vmin 24px;
}
.cf-letter-inner {
    background: var(--color-white);
    border: 1px solid var(--color-light-gray);
    border-radius: 8px;
    padding: 48px 52px;
    transform: rotate(-0.5deg);
    box-shadow: 0 4px 20px rgba(0,0,0,0.04);
}
@media (max-width: 600px) {
    .cf-letter-inner {
        padding: 28px 24px;
        transform: none;
    }
}
.cf-date {
    font-family: var(--font-serif);
    font-size: 1.8rem;
    font-style: italic;
    color: var(--color-secondary-text);
    margin: 0 0 24px;
}
.cf-greeting {
    font-family: var(--font-serif);
    font-size: 2.4rem;
    font-weight: 800;
    color: var(--color-darkgrey);
    margin: 0 0 20px;
    line-height: 1.2;
}
.cf-body p {
    font-family: var(--font-serif);
    font-size: 2rem;
    line-height: 1.7;
    color: var(--color-darkgrey);
    margin: 0 0 18px;
}
.cf-body p:last-child {
    margin-bottom: 0;
}
@media (min-width: 768px) {
    .cf-body { columns: 2; column-gap: 36px; }
    .cf-body p { break-inside: avoid; }
}
@media (min-width: 1024px) {
    .cf-body { columns: 3; column-gap: 32px; }
}
.cf-signoff {
    margin-top: 28px;
    padding-top: 24px;
    border-top: 1px solid var(--color-light-gray);
    display: flex;
    align-items: center;
    gap: 16px;
}
.cf-signoff-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
    border: 2px solid var(--color-light-gray);
}
.cf-signoff-text p {
    font-family: var(--font-serif);
    font-size: 1.6rem;
    font-style: italic;
    color: var(--color-darkgrey);
    margin: 0 0 4px;
}
.cf-signoff-text strong {
    display: block;
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-darkgrey);
    font-style: normal;
    margin-top: 12px;
}

/* ── Objection ── */
.cf-objection {
    max-width: 660px;
    margin: 0 auto;
    padding: 0 24px 6vmin;
}
.cf-objection-inner {
    background: var(--color-lighter-gray);
    border: 1px solid var(--color-light-gray);
    border-radius: 8px;
    padding: 40px 48px;
}
@media (max-width: 600px) {
    .cf-objection-inner { padding: 28px 24px; }
}
.cf-objection-heading {
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-darkgrey);
    margin: 0 0 16px;
    line-height: 1.25;
}
.cf-objection-body p {
    font-size: 2rem;
    line-height: 1.6;
    color: var(--color-secondary-text);
    margin: 0 0 14px;
}
.cf-objection-body p:last-child {
    margin-bottom: 0;
}

/* ── It fits in a lot of places ── */
.cf-places {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 24px 6vmin;
}
.cf-places-heading {
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-darkgrey);
    margin: 0 0 24px;
    text-align: center;
}
.cf-places-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
}
@media (min-width: 600px) {
    .cf-places-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (min-width: 900px) {
    .cf-places-grid { grid-template-columns: repeat(3, 1fr); }
}
.cf-places-card {
    background: var(--color-white);
    border: 1px solid var(--color-light-gray);
    border-radius: 8px;
    padding: 28px 24px;
}
.cf-places-card-label {
    font-family: var(--font-serif);
    font-size: 1.7rem;
    font-weight: 700;
    color: var(--color-darkgrey);
    margin-bottom: 8px;
    line-height: 1.25;
}
.cf-places-card p {
    font-size: 1.35rem;
    line-height: 1.5;
    color: var(--color-secondary-text);
    margin: 0;
}
.cf-places-card a {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    margin-top: 12px;
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-darkgrey);
    text-decoration: none;
    transition: gap 0.2s ease;
}
.cf-places-card a:hover {
    gap: 8px;
    color: var(--color-primary-text);
}

/* ── Subscribe ── */
.cf-subscribe {
    max-width: 660px;
    margin: 0 auto;
    padding: 0 24px 6vmin;
}
.cf-subscribe-inner {
    background: var(--color-lighter-gray);
    border: 1px solid var(--color-light-gray);
    border-radius: 8px;
    padding: 36px 40px;
    text-align: center;
}
@media (max-width: 600px) {
    .cf-subscribe-inner { padding: 28px 24px; }
}
.cf-subscribe p {
    font-size: 1.5rem;
    line-height: 1.5;
    color: var(--color-secondary-text);
    margin: 0 0 20px;
}
.cf-subscribe-form {
    display: flex;
    gap: 8px;
    max-width: 400px;
    margin: 0 auto;
}
@media (max-width: 480px) {
    .cf-subscribe-form { flex-direction: column; }
}
.cf-subscribe-form input {
    flex: 1;
    padding: 10px 14px;
    border: 1px solid var(--color-light-gray);
    border-radius: 6px;
    font-size: 1.4rem;
    color: var(--color-darkgrey);
    background: var(--color-white);
    outline: none;
    font-family: var(--font-sans);
}
.cf-subscribe-form input:focus {
    border-color: var(--color-primary-text);
}
.cf-subscribe-form button {
    padding: 10px 20px;
    border: none;
    border-radius: 6px;
    background: var(--color-darkgrey);
    color: var(--color-white);
    font-size: 1.3rem;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
    transition: opacity 0.15s ease;
    font-family: var(--font-sans);
}
.cf-subscribe-form button:hover {
    opacity: 0.85;
}

/* ── Recent posts ── */
.cf-posts {
    max-width: 660px;
    margin: 0 auto;
    padding: 0 24px 8vmin;
}
.cf-posts-title {
    font-family: var(--font-serif);
    font-size: 1.3rem;
    font-style: italic;
    color: var(--color-secondary-text);
    margin: 0 0 16px;
    text-align: center;
}
.cf-posts-list {
    list-style: none;
    margin: 0;
    padding: 0;
}
.cf-posts-item {
    border-bottom: 1px solid var(--color-light-gray);
}
.cf-posts-item:last-child {
    border-bottom: none;
}
.cf-posts-link {
    display: flex;
    align-items: baseline;
    gap: 16px;
    padding: 12px 0;
    text-decoration: none;
    color: inherit;
    transition: opacity 0.15s ease;
}
.cf-posts-link:hover {
    opacity: 0.7;
}
.cf-posts-date {
    flex-shrink: 0;
    font-family: var(--font-sans);
    font-size: 1.15rem;
    color: var(--color-secondary-text);
    min-width: 70px;
}
.cf-posts-link h3 {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--color-darkgrey);
    margin: 0;
    line-height: 1.35;
}
</style>

<main class="gh-main">
    <div class="gh-container">

        {{!-- ── THE LETTER ── --}}
        <section class="cf-letter">
            <div class="cf-letter-inner">
                <p class="cf-date">{{t "Dari Tim Diskusi Pajak"}}</p>

                <p class="cf-greeting">{{t "Halo,"}}</p>

                <div class="cf-body">
                    <p>{{t "Kalau Anda pernah merasa pusing saat membaca aturan pajak, tenang, Anda tidak sendirian."}}</p>

                    <p>{{t "Banyak aturan perpajakan ditulis dengan bahasa yang formal dan cukup teknis. Belum lagi regulasinya yang terus berubah. Kadang kita cuma ingin tahu jawaban sederhana untuk masalah yang sedang dihadapi, tetapi harus membaca puluhan halaman aturan terlebih dahulu."}}</p>

                    <p><strong>{{t "Karena itulah kami membuat Diskusi Pajak."}}</strong></p>

                    <p>{{t "Tempat ini kami bangun untuk membantu menjelaskan berbagai topik perpajakan dengan bahasa yang lebih mudah dipahami. Bukan sekadar mengutip aturan, tetapi mencoba menjelaskan bagaimana aturan tersebut berlaku dalam situasi nyata yang sering ditemui pelaku usaha, karyawan, maupun praktisi pajak."}}</p>

                    <p>{{t "Mulai dari urusan e-Faktur, PPN, PPh, sampai berbagai pertanyaan yang muncul dalam aktivitas sehari-hari, kami berusaha menyajikannya dengan cara yang lebih ringan dan mudah diikuti."}}</p>

                    <p>{{t "Kami tentu tidak punya semua jawaban. Namun kami berharap Diskusi Pajak bisa menjadi tempat untuk belajar, berbagi pengalaman, dan menemukan solusi bersama."}}</p>

                    <p>{{t "Terima kasih sudah berkunjung. Semoga informasi yang Anda temukan di sini bermanfaat."}}</p>
                </div>

                <div class="cf-signoff">
                    {{#get "authors" filter="slug:tim-redaksi"}}
                    {{#if authors}}
                    {{#foreach authors}}
                    <img class="cf-signoff-avatar" src="{{profile_image}}" alt="{{name}}" loading="lazy" />
                    {{/foreach}}
                    {{/if}}
                    {{/get}}
                    <div class="cf-signoff-text">
                        <p>{{t "Salam hangat,"}}</p>
                        <strong>{{t "Tim {siteTitle}" siteTitle=@site.title}}</strong>
                    </div>
                </div>
            </div>
        </section>

        {{!-- ── "Tapi kan sudah ada Google/Telegram?" ── --}}
        <section class="cf-objection">
            <div class="cf-objection-inner">
                <h2 class="cf-objection-heading">{{t "Tapi kan sudah ada Google atau Telegram?"}}</h2>
                <div class="cf-objection-body">
                    <p>{{t "Benar. Di Google banyak sekali artikel pajak. Di grup Telegram juga banyak diskusi. Tapi masalahnya: informasi di Google kadang tidak update, sumbernya tidak jelas, atau bahasanya terlalu teknis. Di Telegram? Ribut, tidak terstruktur, dan harus scroll panjang untuk mencari jawaban."}}</p>
                    <p>{{t "Di Diskusi Pajak, setiap artikel ditulis dengan bahasa yang mudah dipahami, langkah-langkah konkret yang bisa langsung dipraktikkan, dan selalu mengacu pada aturan yang berlaku. Semua terorganisir rapi dalam satu tempat."}}</p>
                </div>
            </div>
        </section>

        {{!-- ── "It fits in a lot of places" ── --}}
        <section class="cf-places">
            <h2 class="cf-places-heading">{{t "Cocok untuk siapa?"}}</h2>
            <div class="cf-places-grid">
                <div class="cf-places-card">
                    <div class="cf-places-card-label">{{t "Pemilik UMKM"}}</div>
                    <p>{{t "Urus pajak bisnis sendiri tanpa harus bayar konsultan. Panduan lapor omzet, hitung PPh Final, dan SPT Tahunan untuk usaha kecil."}}</p>
                    <a href="{{@site.url}}/tag/pajak-umkm/">{{t "Lihat artikel UMKM"}} &rarr;</a>
                </div>
                <div class="cf-places-card">
                    <div class="cf-places-card-label">{{t "Karyawan"}}</div>
                    <p>{{t "Pahami perhitungan PPh 21 Anda, tahu cara lapor SPT Tahunan, dan tidak perlu bingung saat ada perubahan aturan pajak penghasilan."}}</p>
                    <a href="{{@site.url}}/tag/pph-21/">{{t "Panduan PPh 21"}} &rarr;</a>
                </div>
                <div class="cf-places-card">
                    <div class="cf-places-card-label">{{t "Akuntan & Praktisi"}}</div>
                    <p>{{t "Update aturan terbaru, solusi kasus e-Faktur dan e-Bupot yang sering muncul di lapangan, serta referensi teknis untuk pekerjaan sehari-hari."}}</p>
                    <a href="{{@site.url}}/resources/coretaxpedia/">{{t "TKB Coretax"}} &rarr;</a>
                </div>
                <div class="cf-places-card">
                    <div class="cf-places-card-label">{{t "Mahasiswa"}}</div>
                    <p>{{t "Belajar dasar-dasar perpajakan dengan bahasa yang lebih ringan. Cocok untuk tugas kuliah, skripsi, atau sekedar menambah wawasan perpajakan."}}</p>
                    <a href="{{@site.url}}/resources/">{{t "Jelajahi artikel"}} &rarr;</a>
                </div>
                <div class="cf-places-card">
                    <div class="cf-places-card-label">{{t "Konsultan Pajak"}}</div>
                    <p>{{t "Referensi cepat untuk menjawab pertanyaan klien. Kumpulan artikel yang terstruktur memudahkan Anda mencari solusi tanpa perlu repeat research."}}</p>
                    <a href="{{@site.url}}/faq/">{{t "Cek Tanya Jawab"}} &rarr;</a>
                </div>
                <div class="cf-places-card">
                    <div class="cf-places-card-label">{{t "Bendahara"}}</div>
                    <p>{{t "Kelola PPh dan PPN organisasi atau instansi. Panduan pemotongan, penyetoran, dan pelaporan yang sesuai ketentuan terbaru."}}</p>
                    <a href="{{@site.url}}/resources/">{{t "Panduan bendahara"}} &rarr;</a>
                </div>
            </div>
        </section>

        {{!-- ── SUBSCRIBE ── --}}
        <section class="cf-subscribe">
            <div class="cf-subscribe-inner">
                <p>{{t "Ikuti pembaruan dan bergabung dalam diskusi kami. Ketik email Anda di bawah ini:"}}</p>
                <form class="cf-subscribe-form" data-members-form>
                    <input data-members-email type="email" placeholder="email@anda.com" required />
                    <button type="submit">{{t "Langganan"}}</button>
                </form>
            </div>
        </section>

        {{!-- ── RECENT POSTS ── --}}
        {{#get "posts" limit="8"}}
        {{#if posts}}
        <section class="cf-posts">
            <p class="cf-posts-title">{{t "Artikel terbaru"}}</p>
            <div class="cf-posts-list">
                {{#foreach posts}}
                <article class="cf-posts-item">
                    <a class="cf-posts-link" href="{{url}}">
                        <time class="cf-posts-date">{{date published_at format="DD MMM YYYY"}}</time>
                        <h3>{{title}}</h3>
                    </a>
                </article>
                {{/foreach}}
            </div>
        </section>
        {{/if}}
        {{/get}}

    </div>
</main>
