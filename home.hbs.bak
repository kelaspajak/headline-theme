{{!-- ── tidak ada menampilkan postingan di halaman ini  ── --}}

{{!< default}}
<style>
/* ── Campfire-style letter inside default.hbs ── */
.cf-letter {
    width: 100%;
    max-width: 1000px;
    margin: 0 auto;
    padding: 8vmin 24px;
}
.cf-letter-title {
    font-family: var(--font-sans);
    font-size: 4rem;
    font-weight: 800;
    text-align: center;
    margin: 0 0 28px;
    line-height: 1.15;
    letter-spacing: -0.02em;
}
@media (min-width: 768px) {
    .cf-letter-title { font-size: 5rem; }
}
@media (max-width: 480px) {
    .cf-letter-title br { display: none; }
    .cf-letter-title { font-size: 3.2rem; }
}
.cf-letter-inner {
    background: var(--color-lighter-gray);
    border: 1px solid var(--color-light-gray);
    border-radius: 8px;
    padding: 48px 52px;
    transform: rotate(-0.6deg);
    box-shadow: 0 4px 20px rgba(0,0,0,0.04);
}
@media (max-width: 600px) {
    .cf-letter-inner {
        padding: 28px 24px;
        transform: none;
    }
}
.cf-date {
    font-family: var(--font-serif);
    font-size: 1.8rem;
    font-style: italic;
    color: var(--color-secondary-text);
    margin: 0 0 24px;
}
.cf-greeting {
    font-family: var(--font-serif);
    font-size: 2.4rem;
    font-weight: 800;
    color: var(--color-dark-gray);
    margin: 0 0 20px;
    line-height: 1.2;
}
.cf-body p {
    font-family: var(--font-sans);
    font-size: 1.5rem;
    line-height: 1.7;
    color: var(--color-dark-gray);
    margin: 0 0 18px;
}
.cf-body p:last-child {
    margin-bottom: 0;
}
@media (min-width: 768px) {
    .cf-body { columns: 2; column-gap: 36px; }
    .cf-body p { break-inside: avoid; }
}
/*
@media (min-width: 1024px) {
    .cf-body { columns: 3; column-gap: 32px; }
}
*/
.cf-signoff {
    margin-top: 28px;
    padding-top: 24px;
    border-top: 1px solid var(--color-light-gray);
    display: flex;
    align-items: center;
    gap: 16px;
}
@media (max-width: 480px) {
    .cf-signoff {
        flex-direction: column;
        align-items: flex-start;
    }
}
.cf-signoff-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
    border: 2px solid var(--color-light-gray);
}
.cf-signoff-text p {
    font-family: var(--font-serif);
    font-size: 1.6rem;
    font-style: italic;
    color: var(--color-dark-gray);
    margin: 0 0 4px;
}
.cf-signoff-text strong {
    display: block;
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-dark-gray);
    font-style: normal;
    margin-top: 12px;
}

/* ── Objection ── */
.cf-objection {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 24px 6vmin;
}
.cf-objection-inner {
    background: var(--color-lighter-gray);
    border: 1px solid var(--color-light-gray);
    border-radius: 8px;
    padding: 40px 48px;
}
@media (max-width: 600px) {
    .cf-objection-inner { padding: 28px 24px; }
}
.cf-objection-heading {
    font-family: var(--font-sans);
    font-size: 3rem;
    font-weight: 700;
    margin: 0 0 16px;
    line-height: 1.25;
}
.cf-objection-body p {
    font-size: 1.5rem;
    line-height: 1.6;
    color: var(--color-primary-text);
    margin: 0 0 14px;
}
.cf-objection-body p:last-child {
    margin-bottom: 0;
}

/* ── All these questions have the same answer: Yes! ── */
.cf-answers {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 24px 6vmin;
}
.cf-answers-inner {
    background: var(--color-white);
    border: 1px solid var(--color-light-gray);
    border-radius: 8px;
    padding: 40px 44px;
}
@media (max-width: 600px) {
    .cf-answers-inner { padding: 28px 24px; }
}
.cf-answers-heading {
    font-family: var(--font-sans);
    font-size: 3rem;
    font-weight: 600;
    margin: 0 0 20px;
    text-align: center;
    line-height: 1.25;
}
.cf-answers-heading strong {
    font-weight: 800;
    color: var(--color-dark-gray);
    font-size: 2.4rem;
}
.cf-answers-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0 36px;
}
@media (max-width: 640px) {
    .cf-answers-list { grid-template-columns: 1fr; }
}
.cf-answers-list li {
    padding: 10px 0;
    border-bottom: 1px solid var(--color-lighter-gray);
    margin: 0;
    font-size: 1.4rem;
    line-height: 1.4;
    color: var(--color-primary-text);
    position: relative;
    padding-right: 48px;
}
.cf-answers-list li:after {
    content: "Ada!";
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    display: inline-block;
    background: #d1fae5;
    color: #065f46;
    font-size: 75%;
    font-weight: 700;
    letter-spacing: 0.03em;
    line-height: 1;
    padding: 0.25em 0.45em 0.3em;
    border-radius: 4px;
}
.cf-answers-list li:nth-child(odd):after {
    transform: translateY(-50%) rotate(-2deg);
}
.cf-answers-list li:nth-child(even):after {
    transform: translateY(-50%) rotate(1deg);
}
.cf-answers-list li:nth-last-child(-n+2) {
    border-bottom: none;
}
@media (max-width: 640px) {
    .cf-answers-list li:nth-last-child(-n+1) {
        border-bottom: none;
    }
}
.cf-answers-cta {
    text-align: center;
    margin-top: 20px;
    padding-top: 18px;
    border-top: 1px solid var(--color-light-gray);
}
.cf-answers-cta a {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 1.35rem;
    font-weight: 600;
    color: var(--color-dark-gray);
    text-decoration: none;
    transition: gap 0.2s ease;
}
.cf-answers-cta a:hover {
    gap: 10px;
}

</style>

<main class="gh-main">
    <div class="gh-container">

        {{!-- ── THE LETTER ── --}}
        <section class="cf-letter">
            <h1 class="cf-letter-title">{{t "Pajak semudah yang seharusnya."}}<br />{{t "Bukan serumit yang selama ini dibayangkan."}}</h1>
            <div class="cf-letter-inner">
                <p class="cf-date">{{t "Dari Tim Diskusi Pajak"}}</p>

                <p class="cf-greeting">{{t "Halo,"}}</p>

                <div class="cf-body">
                    <p>{{t "Kalau Anda pernah merasa pusing saat membaca aturan pajak, tenang, Anda tidak sendirian."}}</p>

                    <p>{{t "Banyak aturan perpajakan ditulis dengan bahasa yang formal dan cukup teknis. Belum lagi regulasinya yang terus berubah. Kadang kita cuma ingin tahu jawaban sederhana untuk masalah yang sedang dihadapi, tetapi harus membaca puluhan halaman aturan terlebih dahulu."}}</p>

                    <p><strong>{{t "Karena itulah kami membuat Diskusi Pajak."}}</strong></p>

                    <p>{{t "Tempat ini kami bangun untuk membantu menjelaskan berbagai topik perpajakan dengan bahasa yang lebih mudah dipahami. Bukan sekadar mengutip aturan, tetapi mencoba menjelaskan bagaimana aturan tersebut berlaku dalam situasi nyata yang sering ditemui pelaku usaha, karyawan, maupun praktisi pajak."}}</p>

                    <p>{{t "Mulai dari urusan e-Faktur, PPN, PPh, sampai berbagai pertanyaan yang muncul dalam aktivitas sehari-hari, kami berusaha menyajikannya dengan cara yang lebih ringan dan mudah diikuti."}}</p>

                    <p>{{t "Kami tentu tidak punya semua jawaban. Namun kami berharap Diskusi Pajak bisa menjadi tempat untuk belajar, berbagi pengalaman, dan menemukan solusi bersama."}}</p>

                    <p>{{t "Terima kasih sudah berkunjung. Semoga informasi yang Anda temukan di sini bermanfaat."}}</p>
                </div>

                <div class="cf-signoff">
                    {{#get "authors" filter="slug:tim-redaksi"}}
                    {{#if authors}}
                    {{#foreach authors}}
                    <img class="cf-signoff-avatar" src="{{profile_image}}" alt="{{name}}" loading="lazy" />
                    {{/foreach}}
                    {{/if}}
                    {{/get}}
                    <div class="cf-signoff-text">
                        <p>{{t "Salam hangat,"}}</p>
                        <strong>{{t "Tim {siteTitle}" siteTitle=@site.title}}</strong>
                    </div>
                </div>
            </div>
        </section>

        {{!-- ── "Tapi kan sudah ada Google/Telegram?" ── --}}
        <section class="cf-objection">
            <div class="cf-objection-inner">
                <h2 class="cf-objection-heading">{{t "Tapi kan sudah ada Google atau Telegram?"}}</h2>
                <div class="cf-objection-body">
                    <p>{{t "Benar. Di Google banyak sekali artikel pajak. Di grup Telegram juga banyak diskusi. Tapi masalahnya: informasi di Google kadang tidak update, sumbernya tidak jelas, atau bahasanya terlalu teknis. Di Telegram? Ribut, tidak terstruktur, dan harus scroll panjang untuk mencari jawaban."}}</p>
                    <p>{{t "Di Diskusi Pajak, setiap artikel ditulis dengan bahasa yang mudah dipahami, langkah-langkah konkret yang bisa langsung dipraktikkan, dan selalu mengacu pada aturan yang berlaku. Semua terorganisir rapi dalam satu tempat."}}</p>
                </div>
            </div>
        </section>

        {{!-- ── "All these questions have the same answer: Yes!" ── --}}
        <section class="cf-answers">
            <div class="cf-answers-inner">
                <h2 class="cf-answers-heading">{{t "Semua pertanyaan ini jawabannya:"}} <strong>{{t "Ada!"}}</strong></h2>
                <ul class="cf-answers-list">
                    <li>{{t "Ada panduan cara lapor SPT Tahunan di Coretax?"}}</li>
                    <li>{{t "Bisa buat faktur pajak sendiri tanpa bantuan konsultan?"}}</li>
                    <li>{{t "Ada solusi kalau e-Faktur error pas mau upload?"}}</li>
                    <li>{{t "Cara bikin bukti potong PPh 21/26 yang benar?"}}</li>
                    <li>{{t "Bagaimana cara kompensasi lebih bayar PPN?"}}</li>
                    <li>{{t "Update terbaru aturan perpajakan 2026?"}}</li>
                    <li>{{t "Cara daftar NPWP online lewat Coretax?"}}</li>
                    <li>{{t "Panduan pembuatan e-Bupot PPh 23?"}}</li>
                    <li>{{t "Bagaimana cara menghitung PPh 21 karyawan?"}}</li>
                    <li>{{t "Apakah UMKM wajib lapor SPT Tahun lalu?"}}</li>
                    <li>{{t "Bagaimana cara mengkreditkan pajak masukan?"}}</li>
                    <li>{{t "Ada contoh pengisian SPT PPN?"}}</li>
                </ul>
                <div class="cf-answers-cta">
                    <a href="{{@site.url}}/resources/">{{t "Lihat daftar lengkap artikel"}} &rarr;</a>
                </div>
            </div>
        </section>



    </div>
</main>
