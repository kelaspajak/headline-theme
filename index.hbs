{{!< default}}

<main class="gh-main gh-outer">
    <div class="gh-inner">

        <section class="gh-pagehead">
            <h1 class="gh-pagehead-title">{{t "Latest"}}</h1>
        </section>

        <div class="gh-topic gh-topic-grid">
            <div class="gh-topic-content gh-feed">
                {{#get "posts" filter="tag:-[hash-wilayah,hash-tentang-pic,hash-resources,hash-ppn-ptll]" include="authors" page=pagination.page limit=@config.posts_per_page}}
                    {{#foreach posts}}
                        {{> "loop-grid" has_large_post=false}}
                    {{/foreach}}
                {{/get}}
            </div>
        </div>

    </div>
</main>
