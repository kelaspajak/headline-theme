{{!< default}}

{{#post}}

{{#match slug "=" "partners"}}
<section class="tw-like-directory">
    <div class="tw-directory-wrap">
        <div class="tw-directory-left">
            <h2 class="tw-directory-heading"><span aria-hidden="true">01 / </span>Partner directory</h2>
            <p class="tw-directory-desc">
                <strong>Tim &amp; mitra Diskusi Pajak.</strong>
                <span>Orang dan organisasi yang bantu situs ini bisa berjalan.</span>
            </p>
        </div>
        <div class="tw-directory-right">
            <div class="tw-filters" id="partnerFilters">
                <button type="button" class="tw-filter active" data-filter="all">Semua Lokasi</button>
            </div>
            <div class="tw-table">
                <ul class="tw-list" id="partnerList"></ul>
            </div>
            <span class="tw-error" id="partnerListError" style="display:none">Gagal memuat daftar partner.</span>
        </div>
    </div>
</section>

<style>
.tw-like-directory{max-width:1280px;margin:0 auto;padding:6vmin 24px;font-family:var(--font-sans);color:var(--color-darkgrey)}
.tw-directory-wrap{display:grid;grid-template-columns:1fr;gap:24px}
@media(min-width:900px){.tw-directory-wrap{grid-template-columns:3fr 7fr;gap:32px;align-items:start}}
.tw-directory-heading{font-family:var(--font-mono,var(--font-sans));font-size:1.25rem;font-weight:600;letter-spacing:0.04em;text-transform:uppercase;margin:0 0 16px;color:var(--color-darkgrey)}
.tw-directory-desc{font-size:1.5rem;line-height:1.65;color:var(--color-secondary-text);margin:0}
.tw-directory-desc strong{color:var(--color-darkgrey);font-weight:700}
.tw-filters{display:flex;flex-wrap:wrap;gap:8px}
.tw-filter{appearance:none;border:1px solid var(--color-light-gray);background:var(--color-white);color:var(--color-darkgrey);padding:6px 14px;border-radius:6px;font-size:1.25rem;cursor:pointer}
.tw-filter:hover,.tw-filter.active{background:#1f2937;color:#fff;border-color:#1f2937}
.tw-table{margin-top:24px}
.tw-list{list-style:none;margin:0;padding:0;display:grid;grid-template-columns:1fr;gap:0}
.tw-item{display:block}
.tw-list>.tw-item{border-top:1px solid var(--color-lighter-gray)}
.tw-list>.tw-item:last-child{border-bottom:1px solid var(--color-lighter-gray)}
.tw-link{display:grid;grid-template-columns:1fr auto;gap:16px;align-items:center;padding:22px 12px 22px 24px;text-decoration:none;color:inherit;background:transparent;transition:background .2s ease}
.tw-card{display:flex;align-items:center;gap:12px;min-width:0}
.tw-avatar{width:40px;height:40px;border-radius:50%;object-fit:cover;border:1px solid var(--color-light-gray);flex-shrink:0}
.tw-badge{display:inline-flex;align-items:center;justify-content:center;border-radius:50%;width:36px;height:36px;font-size:1.2rem;font-weight:700;line-height:1;background:var(--color-lighter-gray);color:var(--color-darkgrey);flex-shrink:0}
.tw-cell-name{display:flex;align-items:center;gap:10px;min-width:0}
.tw-name{font-weight:600;font-size:1.4rem;line-height:1.3;color:var(--color-darkgrey);overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.tw-cell-meta{margin-top:4px}
.tw-loc{display:inline-block;color:var(--color-secondary-text);font-size:1.25rem;background:var(--color-lighter-gray);padding:2px 10px;border-radius:999px;line-height:1.35}
.tw-visit{display:inline-flex;align-items:center;gap:6px;font-weight:500;font-size:1.35rem;color:var(--color-darkgrey);white-space:nowrap}
.tw-icon-arrow{width:16px;height:16px}
@media(hover:hover){.tw-link:hover{background:rgba(0,0,0,.05)}}
@media(max-width:639px){.tw-link{grid-template-columns:1fr;gap:10px;padding:18px 14px}.tw-card{flex-wrap:wrap}}
</style>
<script>
(function () {
  var list = document.getElementById('partnerList');
  var filters = document.getElementById('partnerFilters');
  var err = document.getElementById('partnerListError');

  if (!list || !filters) return;

  var xhr = new XMLHttpRequest();
  xhr.open('GET', '/ghost/api/content/authors/?limit=50&key=a64afe0a1b62cafff92e0fda46', true);
  xhr.onload = function () {
    var data = {};
    try { data = JSON.parse(xhr.responseText || '{}'); } catch (e) {}

    var authors = (data.authors || []);
    var html = '';
    var locs = [];
    authors.forEach(function (a) {
      var location = (a.location || '').trim();
      if (!location) return;

      if (locs.indexOf(location) === -1) locs.push(location);

      var avatar = '';
      if (a.profile_image) {
        avatar = '<img class="tw-avatar" src="' + a.profile_image.replace(/"/g, '&quot;') + '" alt="' + (a.name || '').replace(/"/g, '&quot;') + '" loading="lazy" />';
      } else {
        var initial = (a.name || '').trim().charAt(0);
        if (initial) avatar = '<span class="tw-badge">' + initial + '</span>';
      }
      if (!avatar) return;

      var href = (a.website || a.url || '#').replace(/"/g, '&quot;');
      html += '<li class="tw-item" data-location="' + location.replace(/"/g, '&quot;') + '">' +
        '<a href="' + href + '" target="_blank" rel="noopener sponsored" class="tw-link">' +
          '<div class="tw-card">' +
            '<div class="tw-cell-name">' + avatar + '<span class="tw-name">' + (a.name || '').replace(/"/g, '&quot;') + '</span>' +
            '</div>' +
            '<div class="tw-cell-meta"><span class="tw-loc">' + location.replace(/"/g, '&quot;') + '</span></div>' +
          '</div>' +
          '<span class="tw-visit">Kunjungi' +
            '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="tw-icon-arrow" aria-hidden="true"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>' +
          '</span>' +
        '</a>' +
      '</li>';
    });

    list.innerHTML = html;

    locs.sort().forEach(function (loc) {
      var b = document.createElement('button');
      b.type = 'button'; b.className = 'tw-filter';
      b.setAttribute('data-filter', loc); b.textContent = loc;
      b.addEventListener('click', function () {
        var buttons = document.querySelectorAll('#partnerFilters .tw-filter');
        buttons.forEach(function (x) { x.classList.remove('active'); });
        b.classList.add('active');
        var itemLocs = document.querySelectorAll('#partnerList .tw-item');
        itemLocs.forEach(function (item) {
          var itemLoc = (item.getAttribute('data-location') || '').trim();
          item.style.display = itemLoc === loc ? '' : 'none';
        });
      });
      filters.appendChild(b);
    });

    if (!list.children.length && err) err.style.display = '';
  };
  xhr.send();
})();
</script>
{{/match}}

{{^match slug "=" "partners"}}
{{!-- default page --}}
{{/match}}

