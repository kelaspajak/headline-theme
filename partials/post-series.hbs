{{!-- Post Series Navigation --}}
{{!-- Shows related posts in the same tag series --}}
<style>
.ps-series {
    max-width: 720px;
    margin: 0 auto;
    padding: 4vmin 24px;
}
.ps-series-label {
    font-family: var(--font-sans);
    font-size: 1.15rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-mid-gray);
    margin: 0 0 12px;
}
.ps-series-title {
    font-family: var(--font-serif);
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--color-darkgrey);
    margin: 0 0 16px;
    line-height: 1.3;
}
.ps-list {
    list-style: none;
    margin: 0;
    padding: 0;
    border: 1px solid var(--color-light-gray);
    border-radius: 8px;
    overflow: hidden;
}
.ps-item {
    border-bottom: 1px solid var(--color-light-gray);
}
.ps-item:last-child {
    border-bottom: none;
}
.ps-link {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    text-decoration: none;
    color: inherit;
    font-family: var(--font-serif);
    font-size: 1.35rem;
    line-height: 1.4;
    transition: background 0.15s ease;
}
.ps-link:hover {
    background: var(--color-lighter-gray);
}
.ps-num {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-lighter-gray);
    border-radius: 50%;
    font-family: var(--font-sans);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-mid-gray);
}
.ps-item.current .ps-num {
    background: var(--color-darkgrey);
    color: var(--color-white);
}
.ps-item.current .ps-link {
    background: var(--color-lighter-gray);
    font-weight: 700;
}
</style>

{{#if tags.[0]}}
{{#get "posts" filter="tag:{{tags.[0].slug}}" limit="10" include="tags"}}
{{#if posts}}
<div class="ps-series">
    <p class="ps-series-label">{{t "Seri"}}</p>
    <h3 class="ps-series-title">{{tags.[0].name}}</h3>
    <ol class="ps-list">
        {{#foreach posts}}
        <li class="ps-item {{#../post}}id={{id}}{{/../post}}">
            <a class="ps-link" href="{{url}}">
                <span class="ps-num">{{@number}}</span>
                <span>{{title}}</span>
            </a>
        </li>
        {{/foreach}}
    </ol>
</div>
{{/if}}
{{/get}}
{{/if}}
