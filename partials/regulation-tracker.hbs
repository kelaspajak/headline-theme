{{!-- Regulation Tracker Section --}}
<style>
.rt-section {
    max-width: 900px;
    margin: 0 auto;
    padding: 6vmin 24px;
}
.rt-heading {
    font-family: var(--font-serif);
    font-size: 2.2rem;
    font-weight: 700;
    color: var(--color-darkgrey);
    text-align: center;
    margin: 0 0 8px;
    line-height: 1.3;
}
.rt-subheading {
    font-family: var(--font-sans);
    font-size: 1.4rem;
    color: var(--color-secondary-text);
    text-align: center;
    margin: 0 0 36px;
}
.rt-list {
    list-style: none;
    margin: 0;
    padding: 0;
}
.rt-item {
    border-bottom: 1px solid var(--color-light-gray);
    padding: 16px 0;
}
.rt-item:last-child {
    border-bottom: none;
}
.rt-link {
    display: flex;
    align-items: baseline;
    gap: 16px;
    text-decoration: none;
    color: inherit;
    transition: opacity 0.15s ease;
}
.rt-link:hover {
    opacity: 0.7;
}
.rt-date {
    flex-shrink: 0;
    font-family: var(--font-sans);
    font-size: 1.15rem;
    color: var(--color-secondary-text);
    min-width: 100px;
}
.rt-content {
    flex: 1;
}
.rt-title {
    font-family: var(--font-serif);
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--color-darkgrey);
    margin: 0 0 4px;
    line-height: 1.35;
}
.rt-excerpt {
    font-size: 1.25rem;
    color: var(--color-secondary-text);
    margin: 0;
    line-height: 1.5;
}
.rt-tag {
    display: inline-block;
    font-size: 1rem;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 4px;
    margin-right: 6px;
    margin-top: 6px;
}
.rt-tag-pmk { background: #dbeafe; color: #1e40af; }
.rt-tag-per { background: #e0e7ff; color: #3730a3; }
.rt-tag-se { background: #d1fae5; color: #065f46; }
.rt-tag-uu { background: #fef3c7; color: #92400e; }
.rt-more {
    text-align: center;
    margin-top: 24px;
}
.rt-more a {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--color-darkgrey);
    text-decoration: none;
    transition: gap 0.2s ease;
}
.rt-more a:hover { gap: 10px; }
</style>

<section class="rt-section">
    <h2 class="rt-heading">{{t "Update Regulasi Terbaru"}}</h2>
    <p class="rt-subheading">{{t "Ringkasan cepat peraturan perpajakan yang baru berlaku."}}</p>
    <ul class="rt-list">
        {{#get "posts" filter:"tag:update-regulasi" limit="5" include="tags"}}
        {{#foreach posts}}
        <li class="rt-item">
            <a class="rt-link" href="{{url}}">
                <span class="rt-date">{{date format="DD MMM YYYY"}}</span>
                <div class="rt-content">
                    <h3 class="rt-title">{{title}}</h3>
                    {{#if custom_excerpt}}
                    <p class="rt-excerpt">{{custom_excerpt}}</p>
                    {{/if}}
                    {{#foreach tags limit="3"}}
                    <span class="rt-tag rt-tag-{{slug}}">{{name}}</span>
                    {{/foreach}}
                </div>
            </a>
        </li>
        {{/foreach}}
        {{/get}}
    </ul>
    <div class="rt-more">
        <a href="/tag/update-regulasi/">{{t "Lihat semua update regulasi"}} →</a>
    </div>
</section>
