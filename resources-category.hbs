{{!< default}}

{{#contentFor "head"}}
<link rel="stylesheet" type="text/css" href="{{asset "css/ghost-resources.css"}}" />
<style>
    .gh-resources-page {
        --max-width: 1300px;
    }

    /* ── Category hero ── */
    .gh-category-hero {
        text-align: center;
        padding: 6vmin 24px 2vmin;
        max-width: var(--max-width);
        margin: 0 auto;
    }
    .gh-category-hero h1 {
        font-size: clamp(3rem, 5vw, 5rem);
        font-weight: 800;
        letter-spacing: -0.03em;
        line-height: 1.1;
        margin: 0;
    }
    .gh-category-hero p {
        font-family: var(--font-serif);
        font-size: 1.8rem;
        color: #6b7280;
        margin-top: 12px;
        max-width: 560px;
        margin-left: auto;
        margin-right: auto;
    }

    /* ── Category navigation tabs ── */
    .gh-category-nav {
        display: flex;
        justify-content: center;
        gap: 8px;
        padding: 2vmin 24px 4vmin;
        max-width: var(--max-width);
        margin: 0 auto;
        flex-wrap: wrap;
    }
    .gh-category-nav a {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 8px 20px;
        font-size: 1.5rem;
        font-weight: 500;
        color: #6b7280;
        background: transparent;
        border: 1px solid #e5e7eb;
        border-radius: 100px;
        text-decoration: none;
        transition: all 0.15s ease;
    }
    .gh-category-nav a:hover {
        color: #15171a;
        border-color: #d1d5db;
        background: #f9fafb;
    }
    .gh-category-nav a.gh-category-current,
    .gh-category-nav a.active {
        color: #fff;
        background: #15171a;
        border-color: #15171a;
    }

    /* ── Content area ── */
    .gh-category-body {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 0 24px 6vmin;
    }

    /* ── Post grid ── */
    .gh-category-feed {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 32px;
    }

    /* ── Pagination ── */
    .gh-category-pagination {
        display: flex;
        justify-content: center;
        gap: 12px;
        margin-top: 40px;
    }
    .gh-category-pagination a,
    .gh-category-pagination span {
        padding: 8px 16px;
        font-size: 1.4rem;
        font-weight: 500;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        text-decoration: none;
        color: #15171a;
        transition: all 0.15s ease;
    }
    .gh-category-pagination a:hover {
        background: #f9fafb;
        border-color: #d1d5db;
    }
    .gh-category-pagination span {
        color: #9ca3af;
        cursor: default;
    }

    @media (max-width: 1200px) {
        .gh-category-feed {
            grid-template-columns: repeat(2, 1fr);
        }
    }
    @media (max-width: 767px) {
        .gh-category-feed {
            grid-template-columns: 1fr;
            gap: 24px;
        }
        .gh-category-hero {
            padding: 4vmin 16px 1vmin;
        }
        .gh-category-hero h1 {
            font-size: 2.8rem;
        }
    }
</style>
{{/contentFor}}

<main class="gh-main gh-resources-page">
    <div class="gh-category-hero">
        <h1>{{t "Resources"}}</h1>
        <p>{{t "Browse articles by topic."}}</p>
    </div>

    <nav class="gh-category-nav">
        <a href="{{@site.url}}/resources/" class="gh-category-link">{{t "All Resources"}}</a>
        <a href="{{@site.url}}/resources/coretaxpedia/" class="gh-category-link">Coretax Pedia</a>
        <a href="{{@site.url}}/resources/pemeriksaan/" class="gh-category-link">Pemeriksaan</a>
    </nav>

    {{!-- Posts from the channel --}}
    <div class="gh-category-body">
        {{#if posts}}
        <div class="gh-category-feed">
            {{#foreach posts}}
                {{> "loop-grid"}}
            {{/foreach}}
        </div>
        {{else}}
            <p style="text-align:center;color:#9ca3af;padding:4vmin 0;">{{t "No posts found in this category."}}</p>
        {{/if}}

        {{!-- Pagination --}}
        {{#match pagination.pages ">" 1}}
        <nav class="gh-category-pagination">
            {{#if prev}}
                <a href="{{page_url prev}}">&larr; {{t "Previous"}}</a>
            {{/if}}
            <span>{{t "Page"}} {{pagination.page}} {{t "of"}} {{pagination.pages}}</span>
            {{#if next}}
                <a href="{{page_url next}}">{{t "Next"}} &rarr;</a>
            {{/if}}
        </nav>
        {{/match}}
    </div>

</main>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        var path = window.location.pathname.replace(/\/$/, '');
        document.querySelectorAll('.gh-category-link').forEach(function (link) {
            var href = link.getAttribute('href').replace(/\/$/, '');
            if (href === path) {
                link.classList.add('gh-category-current');
            }
        });
    });
</script>

{{#contentFor "body_class"}}resources-template resources-category{{/contentFor}}
