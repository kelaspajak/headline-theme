{{!< default}}

{{#contentFor "head"}}
<link rel="stylesheet" type="text/css" href="https://ghost.org/resources/assets/built/screen.css?v=55a7242196" />
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=STIX+Two+Text:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
<style>
    :root {
        --color-tag: #15171a;
        --color-base: #15171a;
        --color-blue: #3eb0ef;
        --color-whitegrey: #e5eff5;
        --color-wash: #f1f2f3;
    }

    .gh-category-pagination {
        visibility: hidden;
        height: 1px;
        overflow: hidden;
    }

    /* ── Resource tag colors ── */
    .tag-hash-coretaxpedia { --color-tag: #3b82f6; }
    .tag-hash-pemeriksaan  { --color-tag: #f59e0b; }
</style>
{{/contentFor}}

<main class="gh-main">

    {{!-- ── HERO — populated by JS from ghTagData lookup ── --}}
    <header id="gh-tag-head" class="gh-tag-head" style="background-size: cover;">
        <div class="gh-container">
            <div class="gh-tag-head-content">
                <img id="gh-tag-img" class="gh-tag-head-img" src="" alt="" loading="lazy" onerror="this.style.display='none'" />
                <div>
                    <h1 id="gh-tag-name">{{t "Resources"}}</h1>
                    <p id="gh-tag-desc"></p>
                    <span>
                        <span id="gh-tag-count">{{pagination.total}} {{t "posts"}}</span>
                        <a href="{{@site.url}}/resources/">{{t "More resources"}} &rarr;</a>
                    </span>
                </div>
            </div>
        </div>
    </header>

    {{!-- ── PAGE ── --}}
    <div class="gh-page">
        <div class="gh-container">

            {{!-- ── FEATURED POSTS — rendered from channel posts, featured ones get card layout --}}
            {{#foreach posts}}
                {{#if @first}}
                    {{#if featured}}
                    <div class="gh-featuredposts" id="gh-featured">
                    {{/if}}
                {{/if}}
            {{/foreach}}

            {{#foreach posts}}
                {{#if featured}}
                <article class="gh-card post featured">
                    <a class="gh-card-link" href="{{url}}">
                        {{#if feature_image}}
                        <img class="gh-card-image"
                            srcset="{{img_url feature_image size="s"}} 300w,
                                    {{img_url feature_image size="m"}} 720w,
                                    {{img_url feature_image size="l"}} 960w"
                            sizes="(max-width: 1000px) 400px, 700px"
                            src="{{img_url feature_image size="m"}}"
                            alt="{{title}}"
                        />
                        {{/if}}
                        <div class="gh-card-content">
                            <span class="gh-card-meta"><span class="js-tag-name">#coretaxpedia</span> <span class="bull">⁃</span> {{reading_time}}</span>
                            <h2 class="gh-card-title">{{title}}</h2>
                            <p>{{excerpt}}</p>
                            <strong>{{t "Read more"}}</strong>
                        </div>
                    </a>
                </article>
                {{/if}}
            {{/foreach}}

            {{#foreach posts}}
                {{#if @last}}
                    {{#if featured}}
                    </div>
                    {{/if}}
                {{/if}}
            {{/foreach}}

            {{!-- ── POST FEED (list style) — non-featured posts --}}
            <div class="gh-postfeed">
                <div class="gh-feed">
                    {{#foreach posts}}
                    {{#unless featured}}
                    <a class="resource-list-item" href="{{url}}">
                        <div class="resource-list-item-content">
                            <strong>{{title}}</strong>
                            {{#if excerpt}}
                            <p>{{excerpt}}</p>
                            {{/if}}
                        </div>
                        <div class="resource-list-item-right">
                            <span>{{reading_time}}</span>
                            <svg viewBox="0 0 18 27" xmlns="http://www.w3.org/2000/svg"><path d="M2.397 25.426l13.143-11.5-13.143-11.5" stroke-width="3" stroke="currentColor" fill="none" fill-rule="evenodd" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        </div>
                    </a>
                    {{/unless}}
                    {{else}}
                    <p style="text-align:center;color:#9ca3af;padding:4vmin 0;">{{t "No posts found in this category."}}</p>
                    {{/foreach}}
                </div>
            </div>

            {{!-- ── PAGINATION (hidden, for IntersectionObserver) --}}
            {{#match pagination.pages ">" 1}}
            <nav class="gh-category-pagination">
                {{#if prev}}
                    <a href="{{page_url prev}}">&larr; {{t "Previous"}}</a>
                {{/if}}
                <span>{{t "Page"}} {{pagination.page}} {{t "of"}} {{pagination.pages}}</span>
                {{#if next}}
                    <a href="{{page_url next}}">{{t "Next"}} &rarr;</a>
                {{/if}}
            </nav>
            {{/match}}

        </div>
    </div>

</main>

<script>
    // ── Tag data lookup — tambah entry disini untuk tag resources baru ──
    var ghTagData = {
        'coretaxpedia': {
            name: '#coretaxpedia',
            desc: 'Tag ini difungsikan untuk Postingan TKB Coretax',
            color: '#3b82f6',
            img: '{{asset "images/coretaxpedia-cover.jpg"}}',
            bg: '{{asset "images/coretaxpedia-bg.jpg"}}'
        },
        'pemeriksaan': {
            name: '#pemeriksaan',
            desc: 'Artikel tentang pemeriksaan pajak, audit, dan prosedur terkait.',
            color: '#f59e0b',
            img: '{{asset "images/pemeriksaan-cover.jpg"}}',
            bg: '{{asset "images/pemeriksaan-bg.jpg"}}'
        }
    };

    document.addEventListener('DOMContentLoaded', function () {
        // ── 1. Detect which tag from URL ──
        var path = window.location.pathname.replace(/\/$/, '').split('/');
        var slug = path[path.length - 1];
        var data = ghTagData[slug];

        // ── 2. Active nav tab ──
        document.querySelectorAll('.gh-category-link').forEach(function (link) {
            var href = link.getAttribute('href').replace(/\/$/, '');
            if (href === window.location.pathname.replace(/\/$/, '')) {
                link.classList.add('gh-category-current');
            }
        });

        // ── 3. Populate hero ──
        var head = document.getElementById('gh-tag-head');
        var img = document.getElementById('gh-tag-img');
        var name = document.getElementById('gh-tag-name');
        var desc = document.getElementById('gh-tag-desc');

        if (data && head) {
            head.style.backgroundColor = data.color;
            if (data.bg) head.style.backgroundImage = "url('" + data.bg + "')";
            if (img && data.img) { img.src = data.img; img.alt = data.name; }
            if (name) name.textContent = data.name;
            if (desc) desc.textContent = data.desc;
            document.documentElement.style.setProperty('--color-tag', data.color);
        }

        // ── 4. Update tag name in featured card meta ──
        var tagNames = document.querySelectorAll('.js-tag-name');
        if (data) {
            tagNames.forEach(function (el) { el.textContent = data.name; });
        }
    });
</script>

{{#contentFor "body_class"}}resources-template resources-category{{/contentFor}}
