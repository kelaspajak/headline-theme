{{!< default}}

{{#contentFor "head"}}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=STIX+Two+Text:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
<style>
    :root {
        --color-base: #15171a;
        --color-blue: #3eb0ef;
        --color-whitegrey: #e5eff5;
        --color-wash: #f1f2f3;
    }
    #hits { display: none; }
    .tag-infografis    { --color-tag: #3eb0ef; }
    .tag-coretaxpedia  { --color-tag: #f91a1a; }
    .tag-peraturan     { --color-tag: #10b981; }
</style>
{{/contentFor}}

<main class="gh-main">
    <div class="gh-page">
        <div class="gh-container">

            <header class="super">
                <h1 class="superhero">{{t "Mulai Disini"}}</h1>
                <p class="supersub">{{t "Kumpulan panduan, referensi, dan sumber informasi perpajakan untuk membantu Anda memahami aturan, menyelesaikan permasalahan pajak, dan mengikuti perkembangan terbaru."}}</p>
            </header>

            <section class="search">
                <form class="search-input">
                    <label class="hidden" for="search">{{t "Search"}}</label>
                    <input id="search-input" type="text" placeholder="{{t "Search all resources..."}}" autocomplete="off" name="search" aria-label="{{t "Search"}}" />
                    <span id="start-search" class="search-icon"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg></span>
                    <button id="reset-search" class="search-remove" style="display: none;"><svg version="1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M12.707 12L23.854.854a.5.5 0 0 0-.707-.707L12 11.293.854.146a.5.5 0 0 0-.707.707L11.293 12 .146 23.146a.5.5 0 0 0 .708.708L12 12.707l11.146 11.146a.5.5 0 1 0 .708-.706L12.707 12z"/></svg></button>
                </form>
                <div id="hits"></div>
            </section>

            {{!-- ── #infografis ── --}}
            {{#get "posts" include="tags" filter="tag:infografis" limit="5"}}
            {{#if posts}}
            <section class="resource-section tag-infografis">
                {{#foreach posts}}
                {{#if @first}}
                <a class="resource-section-coverlink" href="{{@site.url}}/tag/infografis/">
                    {{#if feature_image}}
                    <img src="{{feature_image}}" alt="{{title}}" loading="lazy" />
                    {{/if}}
                </a>
                <div class="resource-list">
                    <h2>Infografis</h2>
                {{/if}}
                {{/foreach}}

                {{#foreach posts}}
                {{> "loop-zebra"}}
                {{/foreach}}

                <a class="resource-section-morelink" href="{{@site.url}}/tag/infografis/">{{t "Jelajahi seri lengkapnya"}} <span>&rarr;</span></a>
                </div>
            </section>
            {{/if}}
            {{/get}}

            {{!-- ── #coretaxpedia ── --}}
            {{#get "posts" include="tags" filter="tag:coretaxpedia" limit="5"}}
            {{#if posts}}
            <section class="resource-section tag-coretaxpedia">
                {{#foreach posts}}
                {{#if @first}}
                <a class="resource-section-coverlink" href="{{@site.url}}/tag/coretaxpedia/">
                    {{#if feature_image}}
                    <img src="{{feature_image}}" alt="{{title}}" loading="lazy" />
                    {{/if}}
                </a>
                <div class="resource-list">
                    <h2>Coretaxpedia</h2>
                {{/if}}
                {{/foreach}}

                {{#foreach posts}}
                {{> "loop-zebra"}}
                {{/foreach}}

                <a class="resource-section-morelink" href="{{@site.url}}/tag/coretaxpedia/">{{t "Jelajahi seri lengkapnya"}} <span>&rarr;</span></a>
                </div>
            </section>
            {{/if}}
            {{/get}}

            {{!-- ── #peraturan ── --}}
            {{#get "posts" include="tags" filter="tag:peraturan" limit="5"}}
            {{#if posts}}
            <section class="resource-section tag-peraturan">
                {{#foreach posts}}
                {{#if @first}}
                <a class="resource-section-coverlink" href="{{@site.url}}/tag/peraturan/">
                    {{#if feature_image}}
                    <img src="{{feature_image}}" alt="{{title}}" loading="lazy" />
                    {{/if}}
                </a>
                <div class="resource-list">
                    <h2>Peraturan</h2>
                {{/if}}
                {{/foreach}}

                {{#foreach posts}}
                {{> "loop-zebra"}}
                {{/foreach}}

                <a class="resource-section-morelink" href="{{@site.url}}/tag/peraturan/">{{t "Jelajahi seri lengkapnya"}} <span>&rarr;</span></a>
                </div>
            </section>
            {{/if}}
            {{/get}}

        </div>
    </div>
</main>

{{#contentFor "body_class"}}resources-template{{/contentFor}}
