{{!< default}}

{{#contentFor "head"}}
<link rel="stylesheet" type="text/css" href="{{asset "css/ghost-resources.css"}}" />
<style>
    .gh-resources-page {
        --max-width: 1300px;
    }
    .gh-resources-hero {
        text-align: center;
        padding: 8vmin 24px 6vmin;
        max-width: var(--max-width);
        margin: 0 auto;
    }
    .gh-resources-hero h1 {
        font-size: clamp(3.6rem, 6vw, 6rem);
        font-weight: 800;
        letter-spacing: -0.03em;
        line-height: 1.1;
        margin: 0;
    }
    .gh-resources-hero p {
        font-family: var(--font-serif);
        font-size: 2rem;
        color: #6b7280;
        margin-top: 16px;
        max-width: 640px;
        margin-left: auto;
        margin-right: auto;
    }
    .gh-resources-body {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 0 24px;
    }

    /* ── Category sections ── */
    .gh-resources-section {
        padding: 6vmin 0;
        border-top: 1px solid #e5e7eb;
    }
    .gh-resources-section:first-of-type {
        border-top: none;
    }

    /* Per-tag accent colors */
    .tag-hash-coretaxpedia { --color-tag: #3b82f6; }
    .tag-hash-pemeriksaan  { --color-tag: #f59e0b; }

    .gh-resources-section-header {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 40px;
        align-items: center;
        margin-bottom: 40px;
    }
    .gh-resources-section-header img {
        width: 100%;
        border-radius: 12px;
    }
    .gh-resources-section-header h2 {
        font-size: 3.2rem;
        font-weight: 700;
        letter-spacing: -0.02em;
        line-height: 1.2;
        margin: 0;
    }
    .gh-resources-section-header p {
        color: #6b7280;
        margin-top: 8px;
        font-size: 1.6rem;
    }
    .gh-resources-section-header .gh-resources-count {
        display: inline-block;
        margin-top: 8px;
        font-size: 1.4rem;
        font-weight: 500;
        color: var(--color-tag, var(--ghost-accent-color));
    }

    .gh-resources-posts {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }
    .gh-resources-post {
        padding: 16px 0;
        border-bottom: 1px solid #f3f4f6;
    }
    .gh-resources-post:last-child {
        border-bottom: none;
    }
    .gh-resources-post a {
        display: flex;
        justify-content: space-between;
        align-items: center;
        text-decoration: none;
        color: inherit;
    }
    .gh-resources-post a:hover .gh-resources-post-title {
        opacity: 0.7;
    }
    .gh-resources-post-title {
        font-size: 1.8rem;
        font-weight: 500;
        transition: opacity 0.15s ease;
    }
    .gh-resources-post-meta {
        font-size: 1.4rem;
        color: #9ca3af;
        white-space: nowrap;
        margin-left: 16px;
        flex-shrink: 0;
    }
    .gh-resources-link {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        margin-top: 24px;
        font-weight: 600;
        font-size: 1.5rem;
        color: var(--color-tag, var(--ghost-accent-color));
        text-decoration: none;
        transition: opacity 0.15s ease;
    }
    .gh-resources-link:hover {
        opacity: 0.8;
    }

    /* ── Subscribe ── */
    .gh-resources-subscribe {
        text-align: center;
        padding: 8vmin 24px;
        background: #f9fafb;
        margin-top: 40px;
    }
    .gh-resources-subscribe h2 {
        font-size: 3.6rem;
        font-weight: 700;
        letter-spacing: -0.02em;
        margin: 0;
    }
    .gh-resources-subscribe p {
        color: #6b7280;
        margin-top: 12px;
        font-size: 1.6rem;
    }
    .gh-resources-subscribe .gh-btn {
        margin-top: 24px;
    }

    @media (max-width: 767px) {
        .gh-resources-hero {
            padding: 6vmin 16px 4vmin;
        }
        .gh-resources-section-header {
            grid-template-columns: 1fr;
            gap: 24px;
        }
        .gh-resources-post a {
            flex-direction: column;
            align-items: flex-start;
            gap: 4px;
        }
        .gh-resources-post-title {
            font-size: 1.6rem;
        }
        .gh-resources-post-meta {
            margin-left: 0;
        }
        .gh-resources-subscribe h2 {
            font-size: 2.8rem;
        }
    }
</style>
{{/contentFor}}

<main class="gh-main gh-resources-page">
    <div class="gh-resources-hero">
        <h1>{{t "Resources"}}</h1>
        <p>{{t "A collection of articles, guides, and references curated by topic."}}</p>
    </div>

    <div class="gh-resources-body">

        {{!-- Section: #coretaxpedia --}}
        {{#get "posts" filter="tag:hash-coretaxpedia" limit="5"}}
            {{#if posts}}
            <section class="gh-resources-section tag-hash-coretaxpedia">
                <div class="gh-resources-section-header">
                    <div>
                        <h2>#coretaxpedia</h2>
                        <p>{{t "Tag ini difungsikan untuk Postingan TKB Coretax"}}</p>
                        <span class="gh-resources-count">{{t "Latest articles"}}</span>
                    </div>
                </div>

                <div class="gh-resources-posts">
                    {{#foreach posts}}
                    <article class="gh-resources-post">
                        <a href="{{url}}">
                            <span class="gh-resources-post-title">{{title}}</span>
                            <span class="gh-resources-post-meta">{{reading_time}}</span>
                        </a>
                    </article>
                    {{/foreach}}
                </div>

                <a class="gh-resources-link" href="{{@site.url}}/resources/coretaxpedia/">
                    {{t "Explore the full series"}} &rarr;
                </a>
            </section>
            {{/if}}
        {{/get}}

        {{!-- Section: #pemeriksaan --}}
        {{#get "posts" filter="tag:hash-pemeriksaan" limit="5"}}
            {{#if posts}}
            <section class="gh-resources-section tag-hash-pemeriksaan">
                <div class="gh-resources-section-header">
                    <div>
                        <h2>#pemeriksaan</h2>
                        <p>{{t "Artikel tentang pemeriksaan pajak, audit, dan prosedur terkait."}}</p>
                        <span class="gh-resources-count">{{t "Latest articles"}}</span>
                    </div>
                </div>

                <div class="gh-resources-posts">
                    {{#foreach posts}}
                    <article class="gh-resources-post">
                        <a href="{{url}}">
                            <span class="gh-resources-post-title">{{title}}</span>
                            <span class="gh-resources-post-meta">{{reading_time}}</span>
                        </a>
                    </article>
                    {{/foreach}}
                </div>

                <a class="gh-resources-link" href="{{@site.url}}/resources/pemeriksaan/">
                    {{t "Explore the full series"}} &rarr;
                </a>
            </section>
            {{/if}}
        {{/get}}

    </div>
</main>

{{#contentFor "body_class"}}resources-template{{/contentFor}}
