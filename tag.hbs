{{!< default}}

{{#contentFor "head"}}
<style>
/* ── Tag Archive Layout ── */
.edu-tag-header {
    max-width: 900px;
    margin: 0 auto;
    padding: 8vmin 24px 4vmin;
    text-align: center;
}
.edu-tag-breadcrumb {
    font-size: 1.2rem;
    color: var(--color-secondary-text);
    margin-bottom: 12px;
}
.edu-tag-breadcrumb a {
    color: var(--color-secondary-text);
    text-decoration: none;
}
.edu-tag-breadcrumb a:hover {
    color: var(--color-darkgrey);
}
.edu-tag-name {
    font-family: var(--font-serif);
    font-size: 3.6rem;
    font-weight: 800;
    color: var(--color-darkgrey);
    margin: 0 0 12px;
    line-height: 1.2;
    letter-spacing: -0.02em;
}
@media (min-width: 768px) {
    .edu-tag-name { font-size: 4.4rem; }
}
.edu-tag-desc {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-style: italic;
    color: var(--color-secondary-text);
    margin: 0 0 8px;
    line-height: 1.5;
}
.edu-tag-count {
    font-size: 1.2rem;
    color: var(--color-mid-gray);
}
.edu-tag-related {
    margin-top: 24px;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px;
}
.edu-tag-related a {
    display: inline-block;
    padding: 4px 12px;
    background: var(--color-lighter-gray);
    border-radius: 4px;
    font-size: 1.15rem;
    color: var(--color-secondary-text);
    text-decoration: none;
    transition: background 0.15s ease;
}
.edu-tag-related a:hover {
    background: var(--color-light-gray);
    color: var(--color-darkgrey);
}

/* ── Tag Post Feed ── */
.edu-tag-feed {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 24px 8vmin;
}
.edu-tag-section {
    margin-bottom: 4vmin;
}
.edu-tag-section-title {
    font-family: var(--font-serif);
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--color-darkgrey);
    margin: 0 0 16px;
    padding-bottom: 8px;
    border-bottom: 2px solid var(--color-light-gray);
}
.edu-tag-post-list {
    list-style: none;
    margin: 0;
    padding: 0;
}
.edu-tag-post-item {
    border-bottom: 1px solid var(--color-lighter-gray);
}
.edu-tag-post-item:last-child {
    border-bottom: none;
}
.edu-tag-post-link {
    display: flex;
    align-items: baseline;
    gap: 16px;
    padding: 14px 0;
    text-decoration: none;
    color: inherit;
    transition: opacity 0.15s ease;
}
.edu-tag-post-link:hover {
    opacity: 0.7;
}
.edu-tag-post-date {
    flex-shrink: 0;
    font-family: var(--font-sans);
    font-size: 1.1rem;
    color: var(--color-secondary-text);
    min-width: 90px;
}
.edu-tag-post-info {
    flex: 1;
}
.edu-tag-post-title {
    font-family: var(--font-serif);
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--color-darkgrey);
    margin: 0 0 4px;
    line-height: 1.35;
}
.edu-tag-post-excerpt {
    font-size: 1.2rem;
    color: var(--color-secondary-text);
    margin: 0;
    line-height: 1.5;
}
.edu-tag-post-tags {
    flex-shrink: 0;
    display: flex;
    gap: 6px;
}
.edu-tag-mini {
    display: inline-block;
    padding: 2px 8px;
    background: var(--color-lighter-gray);
    border-radius: 3px;
    font-size: 1rem;
    color: var(--color-secondary-text);
}
</style>
{{/contentFor}}

{{#tag}}
<main class="gh-main">

    <header class="edu-tag-header tag-{{slug}}">
        <nav class="edu-tag-breadcrumb">
            <a href="{{@site.url}}">{{@site.title}}</a> → <span>{{name}}</span>
        </nav>
        <h1 class="edu-tag-name">{{name}}</h1>
        {{#if description}}
        <p class="edu-tag-desc">{{description}}</p>
        {{/if}}
        <p class="edu-tag-count">{{plural ../pagination.total empty=(t "No posts") singular=(t "1 post") plural=(t "% posts")}}</p>

        {{!-- Related tags --}}
        <div class="edu-tag-related">
            {{#get "tags" limit="10" include="count.posts"}}
            {{#foreach tags}}
            {{#unless (slug ../slug)}}
            <a href="{{url}}">{{name}} ({{count.posts}})</a>
            {{/unless}}
            {{/foreach}}
            {{/get}}
        </div>
    </header>

    <div class="edu-tag-feed">
        {{#foreach posts}}
        <article class="edu-tag-post-item">
            <a class="edu-tag-post-link" href="{{url}}">
                <span class="edu-tag-post-date">{{date format="DD MMM YYYY"}}</span>
                <div class="edu-tag-post-info">
                    <h2 class="edu-tag-post-title">{{title}}</h2>
                    {{#if custom_excerpt}}
                    <p class="edu-tag-post-excerpt">{{custom_excerpt}}</p>
                    {{/if}}
                </div>
            </a>
        </article>
        {{/foreach}}
    </div>

    {{!-- Pagination --}}
    {{#match pagination.pages ">" 1}}
    <nav class="pagination" style="max-width: 900px; margin: 0 auto; padding: 0 24px 4vmin;" role="navigation" aria-label="Pagination">
        {{#if next}}
        <a class="older-posts" href="{{page_url next}}">{{t "Older Posts"}} &rarr;</a>
        {{/if}}
    </nav>
    {{/match}}

</main>
{{/tag}}
