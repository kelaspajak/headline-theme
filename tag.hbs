{{!< default}}

{{#contentFor "head"}}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=STIX+Two+Text:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
<style>
    :root {
        --color-base: #15171a;
        --color-blue: #3eb0ef;
        --color-whitegrey: #e5eff5;
        --color-wash: #f1f2f3;
    }
</style>
{{/contentFor}}

<main class="gh-main">
    <div class="gh-page">
        <div class="gh-container">
            {{#tag}}
            <header class="super">
                <h1 class="superhero">{{name}}</h1>
                {{#if description}}
                <p class="supersub">{{description}}</p>
                {{/if}}
            </header>
            {{/tag}}

            <div class="gh-postfeed gh-topic-minimal">
                <div class="gh-feed">
                    {{#foreach posts}}
                    <a class="resource-list-item" href="{{url}}">
                        <div class="resource-list-item-content">
                            <strong>{{title}}</strong>
                            <p>{{excerpt}}</p>
                        </div>
                        <div class="resource-list-item-right">
                            <span>{{reading_time}}</span>
                            <svg viewBox="0 0 18 27" xmlns="http://www.w3.org/2000/svg"><path d="M2.397 25.426l13.143-11.5-13.143-11.5" stroke-width="3" stroke="currentColor" fill="none" fill-rule="evenodd" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        </div>
                    </a>
                    {{/foreach}}
                </div>
            </div>

            {{#match pagination.pages ">" 1}}
            <nav class="pagination">
                {{#if prev}}<a href="{{page_url prev}}">&larr; Sebelumnya</a>{{/if}}
                {{#if next}}<a href="{{page_url next}}">Berikutnya &rarr;</a>{{/if}}
            </nav>
            {{/match}}

        </div>
    </div>
</main>
