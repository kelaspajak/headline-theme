{{!< default}}

{{#contentFor "head"}}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=STIX+Two+Text:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
<style>
    :root {
        --color-base: #15171a;
        --color-blue: #3eb0ef;
        --color-whitegrey: #e5eff5;
        --color-wash: #f1f2f3;
        --color-tag: var(--color-blue);
    }

    /* ── Tag Hero ── */
    .gh-tag-head {
        align-items: flex-end;
        background-color: var(--color-tag);
        background-position: 50%;
        background-size: cover;
        color: #fff;
        display: flex;
        margin: 0 0 4vmin;
        padding: 4vmin 4vmin 0;
    }
    .gh-tag-head .gh-container {
        margin: 0 auto;
        max-width: 1300px;
        width: 100%;
        padding: 0 4vmin;
    }
    .gh-tag-head-content {
        display: flex;
        margin: 18vmin 0 0;
        padding: 0 14vmin;
    }
    .gh-tag-head-content > div {
        max-width: 600px;
    }
    .gh-tag-head-content h1 {
        color: #fff;
        font-size: 4.2rem;
        font-weight: 800;
        margin: 0 0 .2em;
        letter-spacing: -0.02em;
    }
    .gh-tag-head-content p {
        font-size: 1.8rem;
        line-height: 1.5em;
        opacity: 0.9;
        margin: 0;
    }
    .gh-tag-head-content > div > span {
        align-items: center;
        display: flex;
        font-size: 1.4rem;
        line-height: 1;
        margin: 2rem 0 4vmin;
    }
    .gh-tag-head-content > div > span > span,
    .gh-tag-head-content > div > span > a {
        border: 1px solid rgba(255,255,255,0.5);
        border-radius: 2rem;
        display: inline-block;
        font-weight: 500;
        letter-spacing: -.5px;
        margin: 0 1.2rem 0 0;
        padding: 6px 14px;
        text-decoration: none;
    }
    .gh-tag-head-content > div > span > span:first-of-type {
        background: #fff;
        color: var(--color-tag);
    }
    .gh-tag-head-content > div > span > a {
        color: #fff;
    }
    .gh-tag-head-content > div > span > a:hover {
        background: rgba(255,255,255,0.15);
    }
    .gh-tag-head-img {
        box-shadow: 0 10px 100px -50px rgba(0,0,0,.6);
        flex-grow: 0;
        flex-shrink: 0;
        height: 100%;
        margin: 0 6vmin -6vmin 0;
        max-width: 320px;
        width: 100%;
        border-radius: 8px;
        object-fit: cover;
    }

    /* ── Featured Posts Grid ── */
    .gh-featuredposts {
        display: grid;
        grid-gap: 4vmin;
        grid-template-columns: repeat(3, 1fr);
        margin: 6vmin auto 0;
        max-width: 1000px;
        padding-top: 60px
    }
    .gh-card-link {
        color: currentColor;
        display: flex;
        flex-direction: column;
        text-decoration: none;
    }
    .gh-card-image {
        border-radius: 8px;
        margin-bottom: 2vmin;
        max-height: 400px;
        object-fit: cover;
        width: 100%;
    }
    .gh-card-meta {
        display: block;
        font-size: 1.3rem;
        font-weight: 500;
        letter-spacing: .5px;
        line-height: 1.2em;
        margin: 0 0 .8rem;
        opacity: .6;
        text-transform: uppercase;
    }
    .gh-card-title {
        font-size: 2.2rem;
        font-weight: 700;
        margin: 0;
        line-height: 1.3em;
    }
    .gh-card-content p {
        -webkit-box-orient: vertical;
        -webkit-line-clamp: 3;
        display: -webkit-box;
        margin: 1rem 0;
        overflow: hidden;
        padding: 0;
        font-size: 1.5rem;
        line-height: 1.5em;
        color: var(--color-midgrey, #738a94);
    }
    .gh-card-content > strong {
        box-shadow: 0 -2px 0 0 inset var(--color-tag);
        color: var(--color-tag);
        display: inline-block;
        font-weight: 500;
        padding: 1px 0;
        font-size: 1.4rem;
    }

    /* ── Post Feed (list) ── */
    .gh-postfeed {
        padding: 6vmin 0;
        margin: 0 auto;
        max-width: 1000px;
    }
    .resource-list-item {
        align-items: center;
        border-bottom: 1px solid var(--color-whitegrey, #e5eff5);
        color: var(--color-base);
        display: flex;
        font-size: 1.6rem;
        justify-content: space-between;
        line-height: 1.15em;
        padding: 25px 0;
        text-decoration: none;
        transition: background 0.4s ease, padding 0.4s ease, color 0.4s ease;
    }
    .resource-list-item:first-of-type {
        border-top: 1px solid var(--color-whitegrey, #e5eff5);
    }
    .resource-list-item:hover {
        background: #f9fafa;
        color: var(--color-tag, var(--color-blue));
        padding: 25px 15px;
        transition: background 0.2s ease, padding 0.2s ease, color 0.2s ease;
    }
    .resource-list-item-content strong {
        font-size: 1.7rem;
        font-weight: 700;
    }
    .resource-list-item-content p {
        -webkit-box-orient: vertical;
        -webkit-line-clamp: 1;
        color: var(--color-midgrey, #738a94);
        display: -webkit-box;
        flex: 0 0 auto;
        margin: .5rem 0 0;
        overflow: hidden;
        transition: color 0.2s ease;
    }
    .resource-list-item:hover .resource-list-item-content p {
        color: var(--color-base);
    }
    .resource-list-item-right {
        flex-shrink: 0;
        margin-left: 4vmin;
        display: flex;
        align-items: center;
    }
    .resource-list-item-right > span {
        font-size: 1.2rem;
        letter-spacing: .5px;
        line-height: 1;
        text-transform: uppercase;
        color: var(--color-midgrey, #738a94);
    }

    /* ── Responsive ── */
    @media (max-width: 900px) {
        .gh-featuredposts {
            grid-template-columns: repeat(2, 1fr);
        }
        .gh-featuredposts .gh-card:last-child {
            display: none;
        }
    }
    @media (max-width: 600px) {
        .gh-tag-head-content {
            flex-direction: column;
            padding-bottom: 6vmin;
        }
        .gh-tag-head-img {
            margin: 0 0 4vmin;
            max-width: 100%;
        }
        .gh-tag-head-content h1 {
            font-size: 3.2rem;
        }
        .gh-tag-head-content p {
            font-size: 1.6rem;
        }
        .gh-featuredposts {
            grid-gap: 6vmin;
            grid-template-columns: 1fr;
        }
        .gh-featuredposts .gh-card:last-child {
            display: block;
        }
        .gh-card-title {
            font-size: 2rem;
        }
    }

    /* ── Infinity scroll: keep pagination sentinel in layout flow ── */
    .pagination {
        visibility: hidden;
        height: 1px;
        overflow: hidden;
    }
</style>
{{/contentFor}}

<main class="gh-main">

    {{#tag}}
    <header class="gh-tag-head tag-{{slug}}">
        <div class="gh-container">
            <div class="gh-tag-head-content">
                {{#if feature_image}}
                <img class="gh-tag-head-img" src="{{feature_image}}" alt="{{name}}" />
                {{/if}}
                <div>
                    <h1>{{name}}</h1>
                    {{#if description}}
                    <p>{{description}}</p>
                    {{/if}}
                    <span>
                        <span>{{plural ../pagination.total empty="No posts" singular="% post" plural="% posts"}}</span>
                        <a href="{{@site.url}}/resources/">{{t "More resources"}} &rarr;</a>
                    </span>
                </div>
            </div>
        </div>
    </header>
    {{/tag}}

    <div class="gh-page">
        <div class="gh-container">

            {{!-- Featured posts --}}
            <div class="gh-featuredposts">
                {{#foreach posts}}
                    {{#if featured}}
                    <article class="gh-card post featured">
                        <a class="gh-card-link" href="{{url}}">
                            {{#if feature_image}}
                            <img class="gh-card-image" src="{{feature_image}}" alt="{{title}}" loading="lazy" />
                            {{/if}}
                            <div class="gh-card-content">
                                <span class="gh-card-meta">{{primary_tag.name}} <span class="bull">⁃</span> {{reading_time}}</span>
                                <h2 class="gh-card-title">{{title}}</h2>
                                <p>{{excerpt}}</p>
                                <strong>{{t "Read more"}}</strong>
                            </div>
                        </a>
                    </article>
                    {{/if}}
                {{/foreach}}
            </div>

            {{!-- Post feed + infinity scroll --}}
            <div class="gh-postfeed">
                <div class="gh-feed">
                    {{#foreach posts}}
                    {{#unless featured}}
                    <a class="resource-list-item" href="{{url}}">
                        <div class="resource-list-item-content">
                            <strong>{{title}}</strong>
                            <p>{{excerpt}}</p>
                        </div>
                        <div class="resource-list-item-right">
                            <span>{{reading_time}}</span>
                            <svg viewBox="0 0 18 27" xmlns="http://www.w3.org/2000/svg"><path d="M2.397 25.426l13.143-11.5-13.143-11.5" stroke-width="3" stroke="currentColor" fill="none" fill-rule="evenodd" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        </div>
                    </a>
                    {{/unless}}
                    {{/foreach}}
                </div>
            </div>

            {{#match pagination.pages ">" 1}}
            <nav class="pagination" role="navigation" aria-label="Pagination">
                {{#if next}}
                <a class="older-posts" href="{{page_url next}}">{{t "Older Posts"}} &rarr;</a>
                {{/if}}
            </nav>
            {{/match}}

        </div>
    </div>
</main>
